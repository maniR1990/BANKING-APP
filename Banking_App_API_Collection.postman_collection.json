            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  createCustomer(data: {\n    name: \"John Doe\",\n    email: \"john@example.com\",\n    address: \"123 Main St\"\n  }) {\n    id\n    name\n    email\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{base_url}}/customer/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customer",
                "graphql"
              ]
            },
            "description": "GraphQL mutation to create a customer."
          },
          "response": []
