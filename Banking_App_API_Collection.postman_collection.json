            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  createCustomer(data: {\n    name: \"{{$randomFullName}}\",\n    email: \"{{dynamicEmail}}\",\n    address: \"{{$randomStreetAddress}}\"\n  }) {\n    id\n    name\n    email\n  }\n}",
